# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Must match an Authorized Redirect URI in your Google Cloud console
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ─── App base URL ──────────────────────────────────────────────────────────────
# Used to build absolute redirect URLs (no trailing slash)
APP_BASE_URL=https://your-domain.com

# ─── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file.
# Defaults to <project-root>/data/reading-star.db when not set.
READINGSTAR_DB_PATH=./data/reading-star.db

# ─── Initial admin account ─────────────────────────────────────────────────────
# Google email address that will be seeded as the first admin user on first run.
# Ignored once a real admin already exists in the database.
INITIAL_ADMIN_EMAIL=admin@example.com

# ─── Credential encryption ─────────────────────────────────────────────────────
# 64-character hex key (32 bytes / AES-256) used to encrypt SMTP credentials
# stored in the database.  Generate with:  openssl rand -hex 32
# macOS:  export READINGSTAR_ENCRYPTION_KEY="<hex>"  in ~/.zshrc
# Linux:  add to /etc/environment or your service's EnvironmentFile
READINGSTAR_ENCRYPTION_KEY=replace_with_output_of_openssl_rand_hex_32

# ─── SMTP email settings ───────────────────────────────────────────────────────
# SMTP is now configured via the Admin → Settings UI; credentials are stored
# encrypted in the database.  No SMTP env vars are required.
# (Legacy env vars SMTP_HOST / SMTP_USER / SMTP_PASS are still honoured as a
#  fallback if the admin UI has not been configured yet.)

# ─── Optional / dev-only ───────────────────────────────────────────────────────
# Set to "1" to disable sample document seeding on startup
# READINGSTAR_DISABLE_SAMPLE_SEED=1

# Set to "1" to enable test auth endpoints (NEVER enable in production)
# READINGSTAR_ENABLE_TEST_AUTH=1
